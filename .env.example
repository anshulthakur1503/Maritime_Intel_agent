# --- DATABASE CONFIGURATION ---
# The credentials for the PostgreSQL container
POSTGRES_USER=your_admin_username
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=maritime_intel

# --- N8N CONFIGURATION ---
# Random long strings for security (e.g., 32+ characters)
N8N_ENCRYPTION_KEY=your_random_encryption_key
N8N_USER_MANAGEMENT_JWT_SECRET=your_random_jwt_secret
GENERIC_TIMEZONE=Asia/Kolkata

# --- AI SERVICE CONFIGURATION ---
# The port where your FastAPI "Brain" will listen
PYTHON_AI_PORT=8000

# --- EXTERNAL APIS (Phase 4) ---
# You'll need these later for Telegram alerts
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here